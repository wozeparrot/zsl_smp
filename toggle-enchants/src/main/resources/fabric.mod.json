  "depends": {
    "fabricloader": ">=0.19.3",
    "minecraft": "26.2",
    "fabric-api": ">=0.154.2+26.2"
  },
  "entrypoints": {
    "main": ["woze.toggleenchants.ToggleEnchants"]
  },
  "mixins": [
    "toggleenchants.mixins.json"
  ]
}
